{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user account information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth ID." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "description": "User's profile picture URL." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role in the application." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp." }
      },
      "required": ["uid", "email", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "Stores customer purchase history.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who placed the order." },
        "items": { "type": "array", "description": "List of items purchased." },
        "total": { "type": "number", "description": "Total order amount." },
        "status": { "type": "string", "enum": ["pending", "shipped", "delivered"], "description": "Current order status." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Order placement timestamp." }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Stores product reviews and ratings.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "The ID of the product being reviewed." },
        "userId": { "type": "string", "description": "The ID of the user who wrote the review." },
        "userName": { "type": "string", "description": "The display name of the reviewer." },
        "rating": { "type": "number", "description": "Star rating (1-5)." },
        "comment": { "type": "string", "description": "Text review content." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Review submission timestamp." }
      },
      "required": ["productId", "userId", "rating", "comment", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Stores product information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "videoUrl": { "type": "string" },
        "category": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "beforeImage": { "type": "string" },
        "afterImage": { "type": "string" }
      },
      "required": ["id", "name", "price", "description", "image", "category", "features"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Order history documents."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product review documents."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product information documents."
    }
  }
}
